{
  "name": "my-time-trace-vscode",
  "displayName": "My Time Trace VSCode",
  "description": "Monitore seu tempo gasto em arquivos e projetos no VS Code com interface moderna e filtros avançados.",
  "icon": "images/my-time-trace-logo.png",
  "publisher": "BelicioBCardoso",
  "version": "0.5.1",
  "author": {
    "name": "Belicio Batista Cardoso",
    "email": "belloinfo@gmail.com"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "license": "MIT",
  "homepage": "https://github.com/beliciobcardoso/MyTimeTraceVSCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/beliciobcardoso/MyTimeTraceVSCode"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "my-time-trace-vscode.startTracking",
        "title": "%my-time-trace-vscode.startTracking.title%",
        "icon": "$(play)"
      },
      {
        "command": "my-time-trace-vscode.pauseTracking",
        "title": "%my-time-trace-vscode.pauseTracking.title%",
        "icon": "$(debug-pause)"
      },
      {
        "command": "my-time-trace-vscode.showStats",
        "title": "%my-time-trace-vscode.showStats.title%",
        "icon": "$(graph)"
      },
      {
        "command": "my-time-trace-vscode.showDeletedProjects",
        "title": "%my-time-trace-vscode.showDeletedProjects.title%",
        "icon": "$(trash)"
      },
      {
        "command": "my-time-trace-vscode.setApiKey",
        "title": "%my-time-trace-vscode.setApiKey.title%",
        "icon": "$(key)"
      },
      {
        "command": "my-time-trace-vscode.viewApiKey",
        "title": "%my-time-trace-vscode.viewApiKey.title%",
        "icon": "$(eye)"
      },
      {
        "command": "my-time-trace-vscode.revokeApiKey",
        "title": "%my-time-trace-vscode.revokeApiKey.title%",
        "icon": "$(trash)"
      },
      {
        "command": "my-time-trace-vscode.syncNow",
        "title": "%my-time-trace-vscode.syncNow.title%",
        "icon": "$(sync)"
      },
      {
        "command": "my-time-trace-vscode.viewSyncStatus",
        "title": "%my-time-trace-vscode.viewSyncStatus.title%",
        "icon": "$(dashboard)"
      }
    ],
    "configuration": {
      "title": "%my-time-trace-vscode.configuration.title%",
      "properties": {
        "myTimeTraceVSCode.idleTimeout": {
          "type": "number",
          "default": 5,
          "description": "%my-time-trace-vscode.configuration.properties.idleTimeout.description%"
        },
        "myTimeTraceVSCode.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%my-time-trace-vscode.configuration.properties.autoStart.description%"
        },
        "myTimeTraceVSCode.showInStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "%my-time-trace-vscode.configuration.properties.showInStatusBar.description%"
        },
        "myTimeTraceVSCode.syncEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic cloud synchronization (requires API Key)"
        },
        "myTimeTraceVSCode.syncInterval": {
          "type": "number",
          "default": 60,
          "description": "Auto-sync check interval in minutes",
          "minimum": 5,
          "maximum": 1440
        }
      }
    },
    "menus": {
      "commandPalette": [
        {
          "command": "my-time-trace-vscode.startTracking"
        },
        {
          "command": "my-time-trace-vscode.pauseTracking"
        },
        {
          "command": "my-time-trace-vscode.showStats"
        },
        {
          "command": "my-time-trace-vscode.showDeletedProjects"
        },
        {
          "command": "my-time-trace-vscode.setApiKey"
        },
        {
          "command": "my-time-trace-vscode.viewApiKey"
        },
        {
          "command": "my-time-trace-vscode.revokeApiKey"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run copy-assets",
    "copy-assets": "mkdir -p out/ui && cp src/ui/*.css out/ui/",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "build": "npm run compile && npm run package",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "i18n": "vscode-nls-dev-create"
  },
  "dependencies": {
    "sqlite3": "^5.1.6",
    "uuid": "^10.0.0",
    "vscode-nls": "5.2.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/sinon": "17.0.4",
    "@types/sqlite3": "^3.1.11",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "sinon": "20.0.0",
    "typescript": "^5.8.3",
    "vscode-nls-dev": "4.0.4"
  },
  "keywords": [
    "time trace",
    "monitoring",
    "Trace code",
    "time code",
    "productivity",
    "statistics",
    "development"
  ],
  "packageManager": "pnpm@10.19.0+sha512.c9fc7236e92adf5c8af42fd5bf1612df99c2ceb62f27047032f4720b33f8eacdde311865e91c411f2774f618d82f320808ecb51718bfa82c060c4ba7c76a32b8"
}
